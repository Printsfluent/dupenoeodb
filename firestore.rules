rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userEmail() {
      return request.auth.token.email.lower();
    }

    function isWorkspaceOwner(workspaceId) {
      return signedIn() &&
        get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid;
    }

    function isWorkspaceMember(workspaceId) {
      return signedIn() && (
        isWorkspaceOwner(workspaceId) ||
        exists(/databases/$(database)/documents/members/$(request.auth.uid + '_' + workspaceId)) == false
      );
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId) || signedIn();
      allow delete: if false;
    }

    match /workspaces/{workspaceId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isWorkspaceOwner(workspaceId);
    }

    match /bases/{baseId} {
      allow read, write: if signedIn();
    }

    match /members/{memberId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /teams/{teamId} {
      allow read, write: if signedIn();
    }

    match /invites/{inviteId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /pendingPlans/{emailId} {
      allow read, write: if signedIn();
    }
  }
}
